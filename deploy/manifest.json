{
  "service_name": "card-studio",
  "project_type": ["node"],
  "artifacts": [
    "Dockerfile",
    "docker-compose.yml",
    ".env.example",
    "manifest.json"
  ],
  "sre_config": {
    "required_infrastructure": [],
    "env_vars_to_fill": []
  },
  "deploy_steps": [
    {
      "title": "解压部署包",
      "description": "tar -xzf deploy-package.tar.gz"
    },
    {
      "title": "初始化数据库",
      "description": "本项目使用 SQLite，无需额外初始化数据库，应用启动时会自动创建 data/stats.db"
    },
    {
      "title": "配置环境变量",
      "description": "复制 package/.env.example 为 package/.env，内容无需修改，开箱即用"
    },
    {
      "title": "启动服务",
      "description": "cd package && docker-compose up -d --build --force-recreate"
    }
  ]
}
